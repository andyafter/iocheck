# Target
IOCHECK_BASE_URL=http://127.0.0.1:3000

# User pacing
IOCHECK_WAIT_MIN_SECONDS=0.1
IOCHECK_WAIT_MAX_SECONDS=1.0

# Traffic mix. Keep writes disabled until you intentionally want to mutate data.
IOCHECK_LOOKUP_WEIGHT=80
IOCHECK_HEALTHZ_WEIGHT=10
IOCHECK_READYZ_WEIGHT=10
IOCHECK_METRICS_WEIGHT=0
IOCHECK_UPSERT_WEIGHT=0
IOCHECK_WRITE_ENABLED=false

# Lookup data. These include values from the seed data plus a benign unknown.
IOCHECK_LOOKUP_IPS=8.8.8.8,185.15.59.224,1.1.1.1
IOCHECK_LOOKUP_DOMAINS=evil-phishing-login.com,suspicious-tracker.net,example.com
IOCHECK_LOOKUP_SHA256S=e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855

# Used only when IOCHECK_WRITE_ENABLED=true and IOCHECK_UPSERT_WEIGHT is above 0.
IOCHECK_UPSERT_SOURCE=locust
IOCHECK_UPSERT_SCORE=50
